# SwiftsReader — Environment Variables
# Copy to .env.local for local dev
# Add ALL of these to Vercel → Project Settings → Environment Variables

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://swiftsreader.com"
# Local: NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Prisma Postgres (claret-bucket) ──────────────────────────────────────────
# From: Vercel dashboard → Prisma integration → your database → connection string
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY"

# ── Clerk ─────────────────────────────────────────────────────────────────────
# From: https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."
CLERK_SECRET_KEY="sk_live_..."
# From: Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET="whsec_..."

# ── Anthropic ─────────────────────────────────────────────────────────────────
# From: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-..."

# ── OpenAI (HD Voice / TTS) ───────────────────────────────────────────────────
# From: https://platform.openai.com → API Keys
# Used for AudioReader HD Voice (TTS-1 standard model)
# Cost: ~$0.015 per 1,000 characters (~$0.75 per 50K-char paper)
OPENAI_API_KEY="sk-..."

# ── Stripe ────────────────────────────────────────────────────────────────────
# From: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY="sk_live_..."
# From: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing Secret
STRIPE_WEBHOOK_SECRET="whsec_..."
# Create products in Stripe Dashboard → Products, then copy the Price IDs
STRIPE_PRICE_STUDENT="price_..."
STRIPE_PRICE_PRO="price_..."

# ── Resend ────────────────────────────────────────────────────────────────────
# From: https://resend.com → API Keys
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="hello@swiftsreader.com"
